{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "方舟进化飞升服务器管理器",
  "version": "0.1.0",
  "identifier": "com.asa.server-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "方舟进化飞升服务器管理器",
        "width": 1600,
        "height": 1020,
        "minWidth": 1600,
        "minHeight": 1020,
        "maxWidth": 1600,
        "maxHeight": 1020,
        "decorations": true,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "backgroundColor": "#020a13"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
