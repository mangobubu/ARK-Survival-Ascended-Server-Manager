{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-get-all-windows",
    "dialog:allow-open"
  ]
}
